generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CLIENT
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REFUSED
  CANCELLED
  PAID
}

enum RoomCategory {
  STANDARD
  SUPERIEURE
  SUITE
  FAMILIALE
}

enum ContactStatus {
  NEW
  READ
  ARCHIVED
}

enum RefundStatus {
  NOT_APPLICABLE
  PENDING
  REFUNDED
}

enum MenuCategory {
  ENTREE
  PLAT
  DESSERT
  BOISSON
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings          Booking[]
  testimonials      Testimonial[]
  tableReservations TableReservation[]
}

model Room {
  id          String       @id @default(cuid())
  name        String
  slug        String?      @unique
  description String
  price       Int
  capacity    Int
  category    RoomCategory
  amenities   String[]     @default([])
  images      String[]     @default([])
  available   Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  bookings Booking[]

  @@index([category])
  @@index([price])
}

model Booking {
  id              String        @id @default(cuid())
  userId          String
  roomId          String
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  status          BookingStatus @default(PENDING)
  comment         String?
  totalPrice      Int
  depositAmount   Int
  refundStatus    RefundStatus  @default(NOT_APPLICABLE)
  refundDueAt     DateTime?
  // Référence de paiement Stripe : renseignée uniquement par le webhook côté serveur,
  // jamais par une requête cliente (le statut PAID ne peut être atteint que par ce biais).
  stripeSessionId String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  room Room @relation(fields: [roomId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([roomId])
  @@index([status])
  @@index([roomId, checkIn, checkOut])
}

model Testimonial {
  id         String   @id @default(cuid())
  userId     String?
  authorName String
  content    String
  rating     Int
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  description String
  price       Int
  category    MenuCategory
  available   Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([category])
}

// Réservation de table pour les dîners en famille (vue piscine), distincte des
// réservations de chambre : pas de prix ni d'acompte, simple créneau à confirmer.
model TableReservation {
  id        String        @id @default(cuid())
  userId    String
  date      DateTime
  time      String
  guests    Int
  comment   String?
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([date])
}
