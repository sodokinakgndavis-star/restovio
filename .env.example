# PostgreSQL (Neon ou Supabase)
# DATABASE_URL : connexion "pooled" (utilisée par l'application à l'exécution)
# DIRECT_URL   : connexion directe/non-poolée (utilisée uniquement par Prisma Migrate)
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Stripe (mode test recommandé — voir https://dashboard.stripe.com/test/apikeys)
# STRIPE_WEBHOOK_SECRET est fourni par `stripe listen --forward-to localhost:PORT/api/webhooks/stripe`
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (notifications e-mail)
RESEND_API_KEY="re_..."
EMAIL_FROM="Restovio <onboarding@resend.dev>"

NODE_ENV="development"
